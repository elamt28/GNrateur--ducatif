# --- MOTEUR D'ANALYSE PÉDAGOGIQUE (NOUVEAUTÉ) ---
def analyser_qualite_cours(contenu, formation):
    """Analyse le contenu pour garantir l'exigence EduForge."""
    score = 0
    remarques = []
    
    if "Chartres" in contenu or "Champhol" in contenu:
        score += 35
        remarques.append("✅ Ancrage local validé.")
    else:
        remarques.append("⚠️ Manque de contexte local.")
        
    if "Barème" in contenu or "/20" in contenu:
        score += 35
        remarques.append("✅ Évaluation structurée présente.")
        
    if len(contenu) > 1500:
        score += 30
        remarques.append("✅ Densité technique conforme pour 60min.")
        
    return score, remarques

# --- GÉNÉRATION DOCX ---
def generer_docx(titre, contenu):
    if not HAS_DOCX: return None
    doc = Document()
    doc.add_heading(titre, 0).alignment = WD_ALIGN_PARAGRAPH.CENTER
    for ligne in contenu.split('\n'):
        if ligne.startswith('# '): doc.add_heading(ligne.replace('# ', ''), level=1)
        elif ligne.startswith('## '): doc.add_heading(ligne.replace('## ', ''), level=2)
        elif ligne.startswith('**'): doc.add_paragraph().add_run(ligne.replace('**', '')).bold = True
        else: doc.add_paragraph(ligne)
    buf = BytesIO()
    doc.save(buf)
    return buf.getvalue()

# --- GÉNÉRATION IA ---
def forger_cours_ia(formation, sujet, lieu, moteur):
    model = genai.GenerativeModel(moteur)
    prompt = f"""
    Agis en expert pédagogique pour le CFA de Chartres.
    Formation : {formation}. Sujet : {sujet}. Lieu : {lieu}.
    Exigence : Ton ludique, humour, technique certifiée.
    Structure : Référentiel, Scénario (Chartres), Notions, Activités, Évaluation/20, Correction.
    """
    return model.generate_content(prompt).text

